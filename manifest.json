{
  "manifest_version": 3,
  "name": "LinkedIn Local AI Commenter",
  "version": "1.0",

  "permissions": [
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "http://localhost:11434/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"]
    }
  ],

  "icons": {
    "128": "extension-logo.jpg"
  },

  "action": {
    "default_icon": "extension-logo.jpg"
  }
}